# Required
DATABASE_URL=postgres://user:password@host:5432/laporfsm
JWT_SECRET=replace-with-strong-secret
API_URL=http://localhost:3000
APP_URL=http://localhost:8080
PORT=3000
CORS_ORIGIN=http://localhost:8080

# App Versioning (optional)
# Format example: 1.0.0-rc.2+6
APP_LATEST_VERSION=1.0.0+1
# Minimum supported version (below this will force update)
APP_MIN_VERSION=1.0.0+1
# Update URLs per platform
APP_ANDROID_URL=https://play.google.com/store/apps/details?id=com.your.app
APP_IOS_URL=https://apps.apple.com/app/id000000000
APP_WEB_URL=https://apps-fsm.undip.ac.id/lapor-fsm
# Optional messaging
APP_UPDATE_MESSAGE=Ada versi baru. Update untuk fitur & keamanan terbaru.
APP_RELEASE_NOTES=Perbaikan bug dan peningkatan performa.

# Supabase Storage (optional, required for cloud uploads)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_publishable_key

# Email (optional, required for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@example.com
SMTP_PASS=your_app_password

# Firebase Admin (optional, required for push notifications)
# You can pass a JSON string or a path to the service account file
FIREBASE_SERVICE_ACCOUNT=path/to/service-account.json
